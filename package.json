{
  "name": "hum",
  "version": "0.24.19",
  "description": "hum - take back what is yours",
  "type": "module",
  "private": true,
  "workspaces": [
    "nestlings/*"
  ],
  "main": "humd/humd.ts",
  "engines": {
    "node": ">=20.20.2 <21"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "test": "vitest run",
    "test:e2e-serve": "vitest run tests/e2e-serve.test.ts",
    "tc": "tsc --noEmit",
    "version:patch": "./scripts/version.sh patch",
    "version:minor": "./scripts/version.sh minor",
    "build": "pnpm -r run build",
    "version:major": "./scripts/version.sh major"
  },
  "keywords": [
    "opencode",
    "claude",
    "cli",
    "daemon",
    "ai"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adiled/hum.git"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opencode-ai/sdk": "^1.3.5",
    "@vue/compiler-sfc": "^3.5.32",
    "better-sqlite3": "^12.9.0",
    "diff": "^8.0.3",
    "node-pty": "^1.1.0",
    "postcss": "^8.5.14",
    "postcss-scss": "^4.0.9",
    "tree-sitter": "0.21.1",
    "tree-sitter-bash": "0.23.3",
    "tree-sitter-c": "0.23.6",
    "tree-sitter-c-sharp": "0.23.1",
    "tree-sitter-cpp": "0.23.4",
    "tree-sitter-go": "0.23.4",
    "tree-sitter-java": "0.23.5",
    "tree-sitter-javascript": "0.23.1",
    "tree-sitter-json": "^0.24.8",
    "tree-sitter-php": "0.23.12",
    "tree-sitter-python": "0.23.6",
    "tree-sitter-ruby": "0.23.1",
    "tree-sitter-rust": "0.24.0",
    "tree-sitter-typescript": "0.23.2",
    "web-tree-sitter": "0.25.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "node-pty",
      "better-sqlite3",
      "tree-sitter",
      "tree-sitter-json",
      "tree-sitter-typescript",
      "tree-sitter-javascript",
      "tree-sitter-python",
      "tree-sitter-go",
      "tree-sitter-rust",
      "tree-sitter-java",
      "tree-sitter-c",
      "tree-sitter-cpp",
      "tree-sitter-ruby",
      "tree-sitter-php",
      "tree-sitter-c-sharp",
      "tree-sitter-bash"
    ]
  }
}
