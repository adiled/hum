#!/usr/bin/env bash
# hum installer — v0.3 (Rust daemon, ensemble mesh).
#
# What this does, in order:
#   1. Detect v0.2 install. If present, hand off to scripts/migrate-from-0-2.sh.
#   2. Ensure prerequisites: claude CLI (≥ MIN_CLAUDE), cargo (for build).
#   3. Build the Rust humd from source — `cargo install --path humd --root $HUM_BIN_ROOT`.
#   4. Mint Ed25519 identity at $HUM_STATE/humd.key if missing.
#   5. Seed an empty peers.json at $HUM_CONFIG/peers.json if missing.
#   6. Install systemd --user unit pointing at the Rust binary.
#   7. Install the OpenCode nestling into ~/.config/opencode/opencode.json.
#   8. Start the daemon.
#
# Idempotent — re-running upgrades in place.
#
# Usage:
#   curl -fsSL https://hum.sh/install | sh
#   ./install                                # from a cloned repo
#   ./install status                         # daemon health
#   ./install logs                           # journalctl tail
#   ./install uninstall                      # remove everything (keeps state)
#   ./install purge                          # remove everything INCLUDING state
#
set -euo pipefail

# ─── XDG dirs ────────────────────────────────────────────────────────────────
XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"
HUM_CONFIG="$XDG_CONFIG_HOME/hum"
HUM_DATA="$XDG_DATA_HOME/hum"
HUM_STATE="$XDG_STATE_HOME/hum"
HUM_BIN_ROOT="$HOME/.local"
HUM_BIN="$HUM_BIN_ROOT/bin/humd"

if [ -n "${XDG_RUNTIME_DIR:-}" ]; then
  HUM_RUNTIME="$XDG_RUNTIME_DIR/hum"
else
  HUM_RUNTIME="/tmp/hum-$(id -u)"
fi
SOCK_BASE="$HUM_RUNTIME/hum.sock"

OPENCODE_CONFIG="$XDG_CONFIG_HOME/opencode/opencode.json"
HUM_REPO_URL="${HUM_REPO_URL:-https://github.com/adiled/hum.git}"
HUM_SRC="$HUM_DATA/src"

MIN_CLAUDE="2.1.86"
MIN_OPENCODE="1.4.3"

CMD="${1:-install}"
OS="$(uname -s)"
IS_ROOT=$([ "$(id -u)" = "0" ] && echo true || echo false)

# ─── helpers ─────────────────────────────────────────────────────────────────

log()  { printf '\033[1m[hum]\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m[hum]\033[0m %s\n' "$*" >&2; }
fail() { printf '\033[1;31m[hum]\033[0m %s\n' "$*" >&2; exit 1; }

version_gte() { printf '%s\n%s\n' "$2" "$1" | sort -V -C; }

read_version() {
  "$1" --version 2>/dev/null | sed -n 's/.*\([0-9][0-9]*\.[0-9][0-9]*\.[0-9][0-9]*\).*/\1/p' | head -1
}

ensure_min_version() {
  local NAME="$1" BIN="$2" MIN="$3"
  if ! command -v "$BIN" >/dev/null 2>&1; then
    fail "$NAME not found on PATH. Install it and re-run."
  fi
  local CUR; CUR="$(read_version "$BIN" || true)"
  if [ -z "$CUR" ]; then fail "$NAME found but couldn't read version."; fi
  if version_gte "$CUR" "$MIN"; then
    log "$NAME ${CUR} ≥ ${MIN} ✓"
  else
    fail "$NAME ${CUR} < ${MIN} — upgrade and re-run."
  fi
}

# ─── prerequisite checks ─────────────────────────────────────────────────────

ensure_prereqs() {
  ensure_min_version "claude CLI" "claude" "$MIN_CLAUDE"
  if ! command -v cargo >/dev/null 2>&1; then
    fail "cargo (rustup) not found. Install rustup: https://rustup.rs"
  fi
}

# ─── v0.2 detection + migration handoff ──────────────────────────────────────

needs_migration() {
  # v0.2 left these landmarks:
  [ -f "$HUM_DATA/src/humd/humd.ts" ] && return 0
  if systemctl --user list-unit-files 2>/dev/null | grep -q '^hum\.service'; then
    local EXEC; EXEC="$(systemctl --user cat hum 2>/dev/null | grep -E '^ExecStart=' | head -1 || true)"
    case "$EXEC" in *humd.ts*|*tsx*) return 0 ;; esac
  fi
  return 1
}

maybe_migrate() {
  if needs_migration; then
    log "v0.2 install detected — running migrate-from-0-2.sh."
    local SCRIPT; SCRIPT="$(dirname "$0")/scripts/migrate-from-0-2.sh"
    if [ ! -f "$SCRIPT" ]; then
      warn "migrate script not found at $SCRIPT — skipping. State may be stale."
      return 0
    fi
    bash "$SCRIPT"
  fi
}

# ─── identity ────────────────────────────────────────────────────────────────

ensure_identity() {
  mkdir -p "$HUM_STATE"
  local KEY="$HUM_STATE/humd.key"
  if [ -s "$KEY" ]; then
    log "humd identity: $KEY ✓"
    return 0
  fi
  # humd mints on first boot if missing. Pre-mint here so users see the
  # HumdId before the daemon starts.
  log "minting humd identity at $KEY (Ed25519, 32 bytes)"
  if command -v openssl >/dev/null 2>&1; then
    openssl genpkey -algorithm Ed25519 -outform DER -out "$KEY.tmp" 2>/dev/null
    # Strip the DER prefix to get raw 32-byte seed — humd's identity.rs
    # reads either format, but raw is the canonical shape it persists.
    tail -c 32 "$KEY.tmp" > "$KEY"
    rm -f "$KEY.tmp"
  else
    # Fallback: 32 random bytes. humd's identity.rs accepts this.
    dd if=/dev/urandom of="$KEY" bs=32 count=1 2>/dev/null
  fi
  chmod 600 "$KEY"
}

# ─── peers.json ──────────────────────────────────────────────────────────────

ensure_peers_config() {
  mkdir -p "$HUM_CONFIG"
  local PEERS="$HUM_CONFIG/peers.json"
  if [ -s "$PEERS" ]; then
    log "peers.json: $PEERS ✓ ($(jq 'length' < "$PEERS" 2>/dev/null || echo "?") entries)"
    return 0
  fi
  cat > "$PEERS" <<'JSON'
[]
JSON
  log "wrote empty peers.json at $PEERS"
  log "  add peers with: hum peer add <humd_id_hex> <transport-hint>"
}

# ─── humd binary ─────────────────────────────────────────────────────────────

build_humd() {
  # If we're in a clone, build from there. Otherwise clone fresh into
  # $HUM_SRC and build.
  local SRC
  if [ -f "$(dirname "$0")/Cargo.toml" ] && grep -q '"humd"' "$(dirname "$0")/Cargo.toml"; then
    SRC="$(dirname "$0")"
  else
    if [ ! -d "$HUM_SRC/.git" ]; then
      log "cloning $HUM_REPO_URL into $HUM_SRC"
      mkdir -p "$HUM_DATA"
      git clone --depth 1 "$HUM_REPO_URL" "$HUM_SRC"
    else
      log "updating $HUM_SRC"
      (cd "$HUM_SRC" && git pull --ff-only --quiet)
    fi
    SRC="$HUM_SRC"
  fi
  log "building Rust humd via cargo install (may take a few minutes)"
  cargo install --quiet --locked --path "$SRC/humd" --root "$HUM_BIN_ROOT" --force
  [ -x "$HUM_BIN" ] || fail "humd binary not at $HUM_BIN after build"
  log "humd installed at $HUM_BIN"
  log "  version: $($HUM_BIN --version 2>&1 || echo 'unknown')"
}

# ─── systemd unit (linux) / launchd plist (macos) ────────────────────────────

install_systemd_unit() {
  case "$OS" in
    Linux) ;;
    *) warn "skipping systemd: not Linux. Run \`$HUM_BIN\` manually."; return 0 ;;
  esac

  local UNIT_DIR="$XDG_CONFIG_HOME/systemd/user"
  local UNIT="$UNIT_DIR/hum.service"
  mkdir -p "$UNIT_DIR"

  cat > "$UNIT" <<EOF
[Unit]
Description=hum daemon (v0.3, Rust + ensemble mesh)
After=network.target

[Service]
Type=simple
Environment=HUM_LOG_LEVEL=info
Environment=XDG_CONFIG_HOME=$XDG_CONFIG_HOME
Environment=XDG_DATA_HOME=$XDG_DATA_HOME
Environment=XDG_STATE_HOME=$XDG_STATE_HOME
Environment=XDG_RUNTIME_DIR=$XDG_RUNTIME_DIR
Environment=HUM_SOCKET=$SOCK_BASE
Environment=CLAUDE_CLI_PATH=$(command -v claude || echo claude)
Environment=PATH=$HUM_BIN_ROOT/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=$HUM_BIN
Restart=on-failure
RestartSec=2s
StandardOutput=journal
StandardError=journal
SyslogIdentifier=hum

[Install]
WantedBy=default.target
EOF
  systemctl --user daemon-reload
  systemctl --user enable hum 2>/dev/null || true
  log "systemd unit installed at $UNIT"
}

start_daemon() {
  case "$OS" in
    Linux)
      systemctl --user restart hum
      sleep 1
      if systemctl --user is-active --quiet hum; then
        log "hum.service running ✓"
      else
        warn "hum.service did not start cleanly — \`hum logs\` to inspect."
      fi
      ;;
    *)
      warn "auto-start unavailable on $OS. Launch manually: $HUM_BIN"
      ;;
  esac
}

# ─── OpenCode nestling ───────────────────────────────────────────────────────

install_opencode_nestling() {
  if ! command -v opencode >/dev/null 2>&1; then
    log "OpenCode not detected — skipping nestling install."
    return 0
  fi
  ensure_min_version "OpenCode" "opencode" "$MIN_OPENCODE" || return 0
  mkdir -p "$(dirname "$OPENCODE_CONFIG")"
  if [ -f "$OPENCODE_CONFIG" ] && grep -q '"opencode-hum"' "$OPENCODE_CONFIG"; then
    log "OpenCode nestling already registered in $OPENCODE_CONFIG"
    return 0
  fi
  # Point OC at the source-tree nestling. Users running the released
  # binary should follow nestlings/opencode/README.md for npm install.
  local PLUGIN_PATH="$HUM_SRC/nestlings/opencode"
  [ -d "$PLUGIN_PATH" ] || PLUGIN_PATH="$(dirname "$0")/nestlings/opencode"
  log "OpenCode nestling source: $PLUGIN_PATH"
  log "  finish setup: cd $PLUGIN_PATH && pnpm install && pnpm build"
  log "  then add the plugin path to $OPENCODE_CONFIG manually."
}

# ─── status / logs / uninstall ───────────────────────────────────────────────

show_status() {
  echo "humd binary:  $HUM_BIN"
  echo "  version:    $($HUM_BIN --version 2>&1 || echo 'not installed')"
  echo "identity:     $HUM_STATE/humd.key $([ -s "$HUM_STATE/humd.key" ] && echo ✓ || echo MISSING)"
  echo "peers.json:   $HUM_CONFIG/peers.json $([ -s "$HUM_CONFIG/peers.json" ] && echo ✓ || echo MISSING)"
  echo "thrum socket: $SOCK_BASE.thrum $([ -S "$SOCK_BASE.thrum" ] && echo ✓ || echo absent)"
  case "$OS" in
    Linux)
      echo "systemd:"
      systemctl --user status hum --no-pager 2>&1 | head -6 || true
      ;;
  esac
}

show_logs() {
  case "$OS" in
    Linux) journalctl --user -u hum --no-pager -n 200 ;;
    *) warn "logs command requires systemd (Linux)" ;;
  esac
}

uninstall() {
  case "$OS" in
    Linux)
      systemctl --user stop hum 2>/dev/null || true
      systemctl --user disable hum 2>/dev/null || true
      rm -f "$XDG_CONFIG_HOME/systemd/user/hum.service"
      systemctl --user daemon-reload 2>/dev/null || true
      ;;
  esac
  rm -f "$HUM_BIN"
  log "uninstalled. State preserved in $HUM_STATE + $HUM_CONFIG."
  log "  run \`hum purge\` to remove state too."
}

purge() {
  uninstall
  rm -rf "$HUM_STATE" "$HUM_CONFIG" "$HUM_DATA"
  log "purged all hum state."
}

# ─── dispatch ────────────────────────────────────────────────────────────────

do_install() {
  log "hum installer — v0.3"
  maybe_migrate
  ensure_prereqs
  build_humd
  ensure_identity
  ensure_peers_config
  install_systemd_unit
  install_opencode_nestling
  start_daemon
  log ""
  log "installed. Try: hum status   /   hum logs"
}

case "$CMD" in
  install|"") do_install ;;
  status)     show_status ;;
  logs)       show_logs ;;
  uninstall)  uninstall ;;
  purge)      purge ;;
  *) fail "unknown command: $CMD (try: install, status, logs, uninstall, purge)" ;;
esac
